# Copiez ce fichier en .env.local et remplissez les valeurs
# depuis Firebase Console → Project settings → Your apps → Web app

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ─── ÉTAPES DE CONFIGURATION ──────────────────────────────────────────────────
#
# 1. FIREBASE PROJET
#    https://console.firebase.google.com → Add project
#    → Build → Authentication → Get started
#    → Sign-in method → activez Google et GitHub
#
# 2. GOOGLE
#    Activé automatiquement avec votre compte Google (rien à faire de plus)
#
# 3. GITHUB
#    a. GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
#    b. Homepage URL : http://localhost:5173  (ou votre domaine en prod)
#    c. Authorization callback URL :
#       https://YOUR-PROJECT.firebaseapp.com/__/auth/handler
#    d. Copiez Client ID + Client Secret dans Firebase Console
#       → Authentication → GitHub → Enable → collez les clés
#
# 4. Domaines autorisés (en production)
#    Firebase Console → Authentication → Settings → Authorized domains
#    → Add domain → votre domaine
